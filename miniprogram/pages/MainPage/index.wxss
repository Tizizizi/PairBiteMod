/* 首页样式 - 帕恰狗主题 */

.container {
  padding: 0;
  padding-bottom: 180rpx;
}

/* 欢迎区域 */
.welcome-section {
  width: 100%;
  background: linear-gradient(135deg, #7CB342 0%, #AED581 100%);
  padding: 60rpx 40rpx 80rpx;
  border-radius: 0 0 60rpx 60rpx;
}

.welcome-card {
  display: flex;
  align-items: center;
}

.pochacco-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: white;
  margin-right: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.emoji-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: white;
  margin-right: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.avatar-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: white;
  margin-right: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  border-radius: 20rpx;
}

.welcome-text {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 40rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 8rpx;
}

.sub-greeting {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 通用区域标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin: 40rpx 16rpx 20rpx;
}

/* 今日状态 */
.status-section {
  margin-top: 0;
  padding: 0 16rpx;
}

.status-card {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(124, 179, 66, 0.15);
}

.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.status-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.status-time {
  font-size: 26rpx;
  color: #999;
}

.status-dishes {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.dish-tag {
  background: #E8F5E9;
  color: #558B2F;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.empty-card {
  background: white;
  border-radius: 24rpx;
  padding: 60rpx 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(124, 179, 66, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.btn-primary {
  padding: 20rpx 50rpx;
  background: linear-gradient(135deg, #7CB342 0%, #558B2F 100%);
  border-radius: 50rpx;
  font-size: 28rpx;
  color: white;
  font-weight: 500;
}

/* 快捷操作 */
.quick-section {
  padding: 0 16rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  background: white;
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(124, 179, 66, 0.1);
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #666;
}

/* 统计区域 */
.stats-section {
  padding: 0 16rpx;
}

.stats-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(124, 179, 66, 0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 48rpx;
  font-weight: 600;
  color: #7CB342;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #E8F5E9;
}

/* 底部装饰 */
.footer-decoration {
  padding: 60rpx 30rpx;
  text-align: center;
}

.footer-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer-mascot {
  width: 50rpx;
  height: 50rpx;
  margin-right: 12rpx;
}

.footer-text {
  font-size: 26rpx;
  color: #AED581;
}

/* 顶部情侣模式 */
.welcome-section.couple-mode {
  background: linear-gradient(135deg, #7CB342 0%, #AED581 100%);
  padding: 60rpx 0 50rpx 0;
}

.couple-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-sizing: border-box;
}

.couple-greeting {
  font-size: 32rpx;
  color: white;
  font-weight: 500;
  margin-bottom: 30rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.couple-avatars-top {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  box-sizing: border-box;
}

.couple-avatar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
}

.couple-avatar-img {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 5rpx solid white;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
  background: #f5f5f5;
}

.couple-avatar-name {
  font-size: 24rpx;
  color: white;
  margin-top: 10rpx;
  max-width: 110rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
}

.couple-heart-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
  padding-top: 15rpx;
}

.couple-heart-beat {
  font-size: 44rpx;
  animation: heartbeat 1.2s ease-in-out infinite;
}

@keyframes heartbeat {
  0% { transform: scale(1); }
  15% { transform: scale(1.25); }
  30% { transform: scale(1); }
  45% { transform: scale(1.2); }
  60% { transform: scale(1); }
  100% { transform: scale(1); }
}

.couple-days {
  font-size: 20rpx;
  color: white;
  margin-top: 4rpx;
  background: rgba(255, 255, 255, 0.3);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

/* 绑定提示 */
.bind-tip-section {
  padding: 30rpx 16rpx 0;
}

.bind-tip-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFE0EC 0%, #FFCDD2 100%);
  border-radius: 24rpx;
  padding: 30rpx;
}

.bind-tip-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.bind-tip-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.bind-tip-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #C62828;
  margin-bottom: 4rpx;
}

.bind-tip-desc {
  font-size: 24rpx;
  color: #E57373;
}

.bind-tip-arrow {
  font-size: 32rpx;
  color: #E57373;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  width: 640rpx;
  background: white;
  border-radius: 32rpx;
  overflow: hidden;
}

.profile-modal .modal-header {
  padding: 50rpx 40rpx 30rpx;
  text-align: center;
  background: linear-gradient(135deg, #7CB342 0%, #AED581 100%);
}

.profile-modal .modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: white;
  margin-bottom: 10rpx;
}

.profile-modal .modal-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.modal-body {
  padding: 40rpx;
}

/* 头像选择区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-btn {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: normal;
}

.avatar-btn::after {
  display: none;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #F5F9F0;
}

.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background: #7CB342;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  border: 4rpx solid white;
}

.avatar-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 昵称输入区域 */
.nickname-section {
  display: flex;
  flex-direction: column;
}

.nickname-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.nickname-input-wrap {
  position: relative;
}

.nickname-input {
  width: 100%;
  height: 90rpx;
  background: #F5F9F0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
}

.nickname-tip {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border-radius: 12rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #689F38;
}

.modal-footer {
  padding: 0 40rpx 40rpx;
}

.modal-btn {
  height: 96rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  border-radius: 48rpx;
}

.modal-btn.confirm.full {
  background: linear-gradient(135deg, #7CB342 0%, #8BC34A 100%);
  color: white;
  font-weight: 500;
}
