.container { min-height: 100vh; background: #F5F9F0; padding-bottom: 120rpx; }
.page-header { padding: 40rpx 30rpx; background: linear-gradient(135deg, #6FCF97 0%, #B8E6C1 100%); }
.page-title { display: block; font-size: 40rpx; font-weight: 600; color: white; margin-bottom: 8rpx; }
.page-subtitle { font-size: 26rpx; color: rgba(255,255,255,0.9); }

.category-list { padding: 24rpx; }
.parent-group { margin-bottom: 8rpx; }

.category-item { display: flex; align-items: center; justify-content: space-between; background: white; border-radius: 20rpx; padding: 24rpx 20rpx; margin-bottom: 8rpx; box-shadow: 0 4rpx 16rpx rgba(124,179,66,0.08); }
.parent-item { border-left: 6rpx solid #6FCF97; }
.child-item { margin-left: 40rpx; background: #FAFCF8; border-left: 4rpx solid #B8E6C1; }

.category-main { display: flex; align-items: center; flex: 1; min-width: 0; }
.expand-arrow { font-size: 20rpx; color: #999; margin-right: 12rpx; transition: transform 0.2s; }
.expand-arrow.expanded { transform: rotate(90deg); }
.child-indent { font-size: 24rpx; color: #CCC; margin-right: 12rpx; }
.category-icon { font-size: 36rpx; margin-right: 16rpx; flex-shrink: 0; }
.category-name { font-size: 28rpx; color: #333; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.child-count { font-size: 22rpx; color: #999; margin-left: 12rpx; background: #F0F0F0; padding: 4rpx 14rpx; border-radius: 16rpx; flex-shrink: 0; }

.category-actions { display: flex; align-items: center; gap: 10rpx; flex-shrink: 0; }

/* ===== 排序箭头：左右排列、加大 ===== */
.sort-arrows {
  display: flex;
  flex-direction: row;
  gap: 6rpx;
  margin-right: 10rpx;
}

.arrow-btn {
  width: 52rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E8F5E9;
  border-radius: 10rpx;
  transition: all 0.15s;
}

.arrow-btn:active {
  background: #6FCF97;
}

.arrow-btn.disabled {
  opacity: 0.2;
}

.arrow-btn.small {
  width: 46rpx;
  height: 38rpx;
}

.arrow-up {
  width: 0; height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 14rpx solid #5AC476;
}

.arrow-down {
  width: 0; height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 14rpx solid #5AC476;
}

.arrow-btn:active .arrow-up { border-bottom-color: white; }
.arrow-btn:active .arrow-down { border-top-color: white; }

.action-btn { font-size: 22rpx; padding: 8rpx 16rpx; border-radius: 16rpx; }
.action-btn.edit { color: #6FCF97; background: #E8F5E9; }
.action-btn.delete { color: #E57373; background: #FFF5F5; }

.children-section { padding-left: 20rpx; }
.add-child-btn { margin-left: 40rpx; text-align: center; padding: 20rpx; background: white; border-radius: 16rpx; border: 2rpx dashed #B8E6C1; color: #6FCF97; font-size: 26rpx; margin-bottom: 16rpx; }

.empty-tip { text-align: center; padding: 80rpx; color: #999; font-size: 28rpx; }

.save-sort-btn { margin: 0 24rpx 16rpx; text-align: center; padding: 28rpx; background: linear-gradient(135deg, #6FCF97 0%, #5AC476 100%); border-radius: 20rpx; color: white; font-size: 30rpx; font-weight: 500; box-shadow: 0 6rpx 20rpx rgba(124,179,66,0.3); }
.add-btn { margin: 0 24rpx; text-align: center; padding: 28rpx; background: white; border-radius: 20rpx; border: 2rpx dashed #B8E6C1; color: #6FCF97; font-size: 30rpx; }

/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; }
.modal-content { width: 640rpx; background: white; border-radius: 24rpx; padding: 40rpx; }
.modal-title { display: block; font-size: 34rpx; font-weight: 600; color: #333; text-align: center; margin-bottom: 30rpx; }
.modal-desc { display: block; font-size: 28rpx; color: #666; line-height: 1.6; margin-bottom: 30rpx; }
.modal-field { margin-bottom: 30rpx; }
.field-label { display: block; font-size: 28rpx; color: #666; margin-bottom: 16rpx; }
.field-input { width: 100%; height: 88rpx; background: #F5F9F0; border-radius: 16rpx; padding: 0 24rpx; font-size: 30rpx; box-sizing: border-box; }
.emoji-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.emoji-item { width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; font-size: 36rpx; border-radius: 16rpx; background: #F5F5F5; border: 2rpx solid transparent; }
.emoji-item.active { background: #E8F5E9; border-color: #6FCF97; }
.custom-emoji-row { display: flex; align-items: center; margin-top: 20rpx; gap: 12rpx; }
.custom-emoji-label { font-size: 26rpx; color: #999; white-space: nowrap; }
.custom-emoji-input { flex: 1; height: 72rpx; background: #F5F5F5; border-radius: 16rpx; padding: 0 20rpx; font-size: 32rpx; text-align: center; }
.custom-emoji-preview { font-size: 26rpx; color: #6FCF97; white-space: nowrap; padding: 10rpx 20rpx; background: #E8F5E9; border-radius: 20rpx; }
.modal-buttons { display: flex; gap: 20rpx; margin-top: 10rpx; }
.modal-btn { flex: 1; text-align: center; padding: 24rpx; border-radius: 44rpx; font-size: 28rpx; }
.modal-btn.cancel { background: #F5F5F5; color: #666; }
.modal-btn.confirm { background: linear-gradient(135deg, #6FCF97 0%, #5AC476 100%); color: white; font-weight: 500; }
.modal-btn.confirm.disabled { opacity: 0.5; }
.transfer-list { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 30rpx; }
.transfer-item { padding: 16rpx 28rpx; font-size: 28rpx; color: #666; background: #F5F5F5; border-radius: 30rpx; border: 2rpx solid transparent; }
.transfer-item.active { color: #5AC476; background: #E8F5E9; border-color: #6FCF97; }
.loading { text-align: center; padding: 60rpx; color: #999; font-size: 28rpx; }


.emoji-hint { font-size: 22rpx; color: #CCC; margin-top: 16rpx; }
.emoji-reset { font-size: 24rpx; color: #E57373; margin-top: 12rpx; text-align: center; padding: 12rpx; }