.container { padding-bottom: 60rpx; }
.page-header { padding: 40rpx 30rpx; background: linear-gradient(135deg, #6FCF97 0%, #B8E6C1 100%); display: flex; align-items: center; justify-content: space-between; }
.page-title { display: block; font-size: 44rpx; font-weight: 600; color: white; margin-bottom: 8rpx; }
.page-subtitle { font-size: 26rpx; color: rgba(255,255,255,0.9); }

/* 搜索框 */
.search-section { padding: 16rpx 16rpx 0; margin-top: -10rpx; }
.search-box { display: flex; align-items: center; background: white; border-radius: 50rpx; padding: 16rpx 24rpx 16rpx; box-shadow: 0 4rpx 16rpx rgba(124,179,66,0.12); }
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 26rpx; color: #333; }
.search-clear { font-size: 26rpx; color: #CCC; padding: 8rpx; }

/* 筛选排序栏 */
.filter-sort-bar { display: flex; align-items: center; margin: 6rpx 16rpx -10rpx; background: white; border-radius: 16rpx; padding: 0 8rpx; box-shadow: 0 2rpx 12rpx rgba(124,179,66,0.08); }
.bar-item { flex: 1; display: flex; align-items: center; justify-content: center; padding: 18rpx 0; font-size: 26rpx; color: #666; }
.bar-item.active { color: #5AC476; font-weight: 500; }
.bar-arrow { font-size: 18rpx; margin-left: 6rpx; }
.bar-divider { width: 2rpx; height: 28rpx; background: #E8E8E8; }

/* 下拉面板 */
.dropdown-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.3); z-index: 100; }
.dropdown-panel { position: relative; z-index: 101; margin: 0 16rpx; background: white; border-radius: 0 0 20rpx 20rpx; padding: 24rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1); }
.dropdown-section { margin-bottom: 24rpx; }
.dropdown-title { display: block; font-size: 24rpx; color: #999; margin-bottom: 16rpx; font-weight: 500; }
.dropdown-tags { display: flex; flex-wrap: wrap; gap: 16rpx; }
.dropdown-tag { padding: 12rpx 24rpx; font-size: 26rpx; color: #555; background: #F5F5F5; border-radius: 28rpx; border: 2rpx solid transparent; }
.dropdown-tag.active { color: #5AC476; background: #E8F5E9; border-color: #6FCF97; }
.dropdown-tag.child-tag { font-size: 24rpx; padding: 8rpx 20rpx; color: #888; background: #FAFAFA; }
.dropdown-tag.child-tag.active { color: #5AC476; background: #E8F5E9; border-color: #6FCF97; }
.dropdown-clear { text-align: center; padding: 16rpx; font-size: 26rpx; color: #E57373; }
.dropdown-sort-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 16rpx; font-size: 28rpx; color: #555; border-bottom: 1rpx solid #F5F5F5; }
.dropdown-sort-item:last-child { border-bottom: none; }
.dropdown-sort-item.active { color: #5AC476; font-weight: 500; }
.sort-arrow { font-size: 24rpx; color: #5AC476; }

/* 可折叠筛选 */
.filter-cat-group { width: 100%; margin-bottom: 8rpx; }
.dropdown-tag-row { display: flex; align-items: center; gap: 8rpx; }
.expand-toggle { font-size: 20rpx; color: #999; padding: 8rpx 12rpx; }
.filter-children { display: flex; flex-wrap: wrap; gap: 12rpx; padding: 8rpx 0 4rpx 16rpx; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 100rpx 60rpx; }
.empty-image { width: 300rpx; height: 300rpx; margin-bottom: 40rpx; }
.empty-title { font-size: 34rpx; font-weight: 500; color: #333; margin-bottom: 16rpx; }
.empty-desc { font-size: 28rpx; color: #999; }

/* 历史列表 */
.history-list { padding: 16rpx 16rpx; }
.history-item { background: white; border-radius: 24rpx; padding: 30rpx; box-shadow: 0 4rpx 20rpx rgba(124,179,66,0.1); margin-bottom: 5rpx; }
mp-slideview { margin-bottom: 20rpx; }
.delete-btn, mp-slideview .delete-btn, .weui-slideview__btn.delete-btn { background-color: #E57373 !important; }
.mark-btn, mp-slideview .mark-btn, .weui-slideview__btn.mark-btn { background-color: #42A5F5 !important; }
.history-item.marked { background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%); border: 2rpx solid #FFD54F; }

.history-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.history-date { display: flex; align-items: center; }
.date-icon { font-size: 28rpx; margin-right: 8rpx; }
.date-text { font-size: 30rpx; font-weight: 500; color: #333; }
.header-right { display: flex; flex-direction: column; align-items: flex-end; gap: 8rpx; }
.meal-status { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: 500; }
.meal-status.status-done { background: #E8F5E9; color: #4CAF50; }
.meal-status.status-pending { background: #FFF3E0; color: #FF9800; }
.history-time { font-size: 26rpx; color: #999; }

.history-dishes { display: flex; flex-wrap: wrap; gap: 20rpx; margin-bottom: 24rpx;  }
.history-dish { display: flex; align-items: center; background: #F5F9F0; border-radius: 40rpx; padding: 8rpx 24rpx 8rpx 8rpx; }
.history-dish-image { width: 56rpx; height: 56rpx; border-radius: 50%; margin-right: 12rpx; }
.history-dish-name { font-size: 26rpx; color: #5AC476; }

.history-remark { display: flex; align-items: center; background: #FFF9E6; border-radius: 12rpx; padding: 16rpx 20rpx; margin-bottom: 20rpx; }
.remark-icon { font-size: 28rpx; margin-right: 12rpx; }
.remark-text { font-size: 26rpx; color: #996600; }

.history-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 20rpx; border-top: 2rpx solid #F5F9F0; }
.history-creator { font-size: 26rpx; color: #999; }
.footer-right { display: flex; align-items: center; gap: 16rpx; }
.dish-count { font-size: 26rpx; color: #6FCF97; font-weight: 500; }

/* 评论数徽标 */
.note-badge { display: flex; align-items: center; gap: 4rpx; background: #F0F7FF; padding: 4rpx 14rpx; border-radius: 16rpx; }
.note-badge-icon { font-size: 22rpx; }
.note-badge-count { font-size: 22rpx; color: #5B9BD5; font-weight: 500; }

/* 无结果 */
.no-result { text-align: center; padding: 60rpx; color: #999; font-size: 28rpx; }

.load-more { text-align: center; padding: 30rpx; }
.load-more text { font-size: 28rpx; color: #6FCF97; }
.no-more { text-align: center; padding: 15rpx 30rpx 30rpx; }
/*.no-more text { font-size: 26rpx; color: #CCC; }*/

.tip-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; }
.tip-content { background: white; border-radius: 32rpx; padding: 50rpx 40rpx; width: 500rpx; display: flex; flex-direction: column; align-items: center; animation: tipPop 0.3s ease-out; }
@keyframes tipPop { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }
.tip-image { width: 200rpx; height: 200rpx; margin-bottom: 30rpx; }
.tip-text { font-size: 30rpx; color: #333; text-align: center; margin-bottom: 40rpx; line-height: 1.6; }
.tip-btn { background: linear-gradient(135deg, #6FCF97 0%, #B8E6C1 100%); color: white; font-size: 28rpx; padding: 20rpx 60rpx; border-radius: 40rpx; box-shadow: 0 6rpx 20rpx rgba(124,179,66,0.3); }



/* 有子分类的一级类目独占一行 */
.filter-parent-block { width: 100%; margin-top: 16rpx; }
.parent-tag { margin-bottom: 12rpx; }
.filter-children-inline { display: flex; flex-wrap: wrap; gap: 12rpx; padding-left: 16rpx; }


.total-count { display: block; font-size: 28rpx; color: #CCC; font-weight: 600; margin-top: 12rpx; }
.history-bottom-blessing { display: flex; align-items: center; justify-content: center; margin-top: 20rpx; }
.bottom-mascot { width: 50rpx; height: 50rpx; margin-right: 12rpx; }
.bottom-text { font-size: 26rpx; color: #B8E6C1; }
.no-more-center { flex: 1; text-align: center; font-size: 26rpx; color: #CCC; }

